<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login User</title>
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
</head>
<body>
    <section>
        <div class="row">
            <div class="col-4"></div>
            <div class="col-4">
                <h3>Login Form</h3>
            </div>
            <div class="col-4"></div>
        </div>
        <div class="row">
            <div class="col-4"></div>
            <div class="col-4">
                <form action="/api/login" method="post">
                    <label for="useremail" class="form-label">Username</label>
                    <input type="text" class="form-control" name="useremail" id="useremail" required>
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" name="userpassword" id="userpassword" required>
                    <div class="mt-3">
                        <input type="submit" value="Submit" class="form-control btn btn-primary">
                    </div>
                </form>
            </div>
            <div class="col-4"></div>
        </div>
    </section>
</body>
</html>