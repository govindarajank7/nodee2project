<%- include('header') %>
    <main>
        <div class="row">
            <h2>User List</h2>
            <% if (typeof message !== 'undefined') { %>
                <div class="alert alert-success fade show"><%= message %></div>
            <% } %>
            <table class="table table-striped">
                <tr>
                    <th>Profile Photo</th>
                    <th>Username</th>
                    <th>Useremail</th>
                    <th>User Birthdate</th>
                    <th>User Role</th>
                </tr>
                <% users.forEach(user => {%>
                    <tr>
                        <td><img src="/uploads/<%= user.userphoto%>" alt="No Image" class="img img-responsive" style="width:50px;height:50px;"></td>
                        <td><%= user.username%></td>
                        <td><%= user.useremail%></td>
                        <td><%= user.userbirthdate %></td>
                        <td><%= user.userrole%></td>
                    </tr>
                <% }) %>
            </table>
        </div>

        <!-- Toast Container -->
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="notificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header">
                    <strong class="me-auto">Notification</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body" id="toastMessage"></div>
            </div>
        </div>
    </main>
<% include('footer') %>
<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const toastEl = document.getElementById('notificationToast');
    const toast = new bootstrap.Toast(toastEl);

    socket.on('userChange', (data) => {
        let message = '';
        if (data.action === 'created') {
            message = `New user ${data.user.username} created.`;
        } else if (data.action === 'updated') {
            message = `User ${data.user.username} updated.`;
        } else if (data.action === 'deleted') {
            message = `User with ID ${data.userId} deleted.`;
        }
        document.getElementById('toastMessage').textContent = message;
        toast.show();
    });
</script>